#!/bin/sh
# Global post-checkout hook
# - Updates tmux pane title with new branch name (for AI agent sessions)
# - Chains to git-lfs
# - Chains to repo-specific post-checkout.local

# Resolve git dir once (used for HEAD read and repo-local hook chaining)
_git_dir="$(git rev-parse --git-dir 2>/dev/null)" || _git_dir=""

# --- tmux pane title update ---
# Only run on branch checkouts ($3 == 1), skip file checkouts
# Only run inside tmux to avoid errors on bare terminals
if [ "${3:-0}" = "1" ] && [ -n "$TMUX" ] && [ -n "$_git_dir" ]; then
    # Read new branch from .git/HEAD (same logic as .bashrc)
    _head_file="$_git_dir/HEAD"
    if [ -f "$_head_file" ]; then
        read -r _hc < "$_head_file" 2>/dev/null
        case "$_hc" in
            "ref: refs/heads/"*) _branch=" (${_hc#ref: refs/heads/})" ;;
            "ref: "*)            _branch=" (${_hc#ref: })" ;;
            ?*)                  _branch=" ($(printf '%.8s' "$_hc"))" ;;
            *)                   _branch="" ;;
        esac
        # Update tmux pane user options (used by pane-border-format in .tmux.conf)
        tmux set -p @pane_branch "$_branch" 2>/dev/null || true
        # Also update the terminal title for non-tmux-border consumers
        # Use case for POSIX-safe $HOME prefix stripping
        case "$PWD" in
            "$HOME"/*) _dir="~${PWD#"$HOME"}" ;;
            *)         _dir="$PWD" ;;
        esac
        printf '\033]2;%s%s\033\\' "$_dir" "$_branch"
    fi
    unset _head_file _hc _branch _dir
fi

# --- git-lfs ---
if command -v git-lfs >/dev/null 2>&1; then
    git lfs post-checkout "$@"
fi

# --- repo-specific hook ---
if [ -n "$_git_dir" ]; then
    _repo_hook="$_git_dir/hooks/post-checkout.local"
    if [ -x "$_repo_hook" ]; then
        "$_repo_hook" "$@"
    fi
    unset _repo_hook
fi
unset _git_dir

# --- BEGIN BEADS INTEGRATION v1.0.4 ---
# This section is managed by beads. Do not remove these markers.
if command -v bd >/dev/null 2>&1; then
  export BD_GIT_HOOK=1
  _bd_timeout=${BEADS_HOOK_TIMEOUT:-300}
  if command -v timeout >/dev/null 2>&1; then
    timeout "$_bd_timeout" bd hooks run post-checkout "$@"
    _bd_exit=$?
    if [ $_bd_exit -eq 124 ]; then
      echo >&2 "beads: hook 'post-checkout' timed out after ${_bd_timeout}s — continuing without beads"
      _bd_exit=0
    fi
  else
    bd hooks run post-checkout "$@"
    _bd_exit=$?
  fi
  if [ $_bd_exit -eq 3 ]; then
    echo >&2 "beads: database not initialized — skipping hook 'post-checkout'"
    _bd_exit=0
  fi
  if [ $_bd_exit -ne 0 ]; then exit $_bd_exit; fi
fi
# --- END BEADS INTEGRATION v1.0.4 ---
